#!/bin/bash
#SBATCH --job-name=multimodal-textbook
#SBATCH --account=infra01
#SBATCH --partition=normal
#SBATCH --reservation=SD-69241-apertus-1-5
#SBATCH --environment=nemo_26_02
#SBATCH --time=12:00:00
#SBATCH --cpus-per-task=288
#SBATCH --output=/iopsstor/scratch/cscs/%u/apertus/multimodal-data/01-dataset-download/logs/multimodal-textbook-%j.out
#SBATCH --error=/iopsstor/scratch/cscs/%u/apertus/multimodal-data/01-dataset-download/logs/multimodal-textbook-%j.err

# DAMO-NLP-SG / multimodal_textbook
#   https://huggingface.co/datasets/DAMO-NLP-SG/multimodal_textbook
#
# 6.5M keyframes + 0.8B ASR tokens, interleaved, from 22,697 hours of
# instructional videos (math, physics, chemistry, ...).
#   - 610K interleaved samples
#   - Two JSON manifests (~11.8 GB each): full + face-filtered
#   - Images as 20 split tar.gz parts of 28.3 GB each (~566 GB total)
#   - License: Apache 2.0
#
# Download strategy: few-but-large files → huggingface-cli + HF_TRANSFER.
# After download, reconstruct + extract the image tar.
#
# Disk requirements:
#   download area : ~607 GB (tar parts + merged + JSON)
#   extracted     : ~600 GB additional
#   total peak    : ~1.2 TB during extraction; drops to ~600 GB if the
#                   merged tar.gz is deleted after extract.

set -euo pipefail

DEST=/capstor/store/cscs/swissai/infra01/vision-datasets/raw/cooldown/damo_multimodal_textbook
mkdir -p "$DEST"

# hf_transfer lives in the shared pip-packages dir (matches fine-t2i, etc.).
export PYTHONPATH="/capstor/store/cscs/swissai/infra01/MLLM/pip-packages:${PYTHONPATH:-}"
export PATH="/capstor/store/cscs/swissai/infra01/MLLM/pip-packages/bin:${PATH}"
export HF_HUB_ENABLE_HF_TRANSFER=1
export HF_HUB_DOWNLOAD_TIMEOUT=600

echo "=== downloading DAMO-NLP-SG/multimodal_textbook to $DEST ==="
date -u +%Y-%m-%dT%H:%M:%SZ

# Exclude playground.zip (16 GB of ipynb / supplementary demo — not needed
# for training). Keep both JSONs so downstream can choose face-filtered or not.
time huggingface-cli download DAMO-NLP-SG/multimodal_textbook \
    --repo-type dataset \
    --local-dir "$DEST" \
    --exclude "playground.zip"

echo
echo "=== reconstructing image archive ==="
# The 20 parts concatenate into a single ~566 GB tar.gz.
cd "$DEST"
if [[ ! -f dataset_images_interval_7.tar.gz ]]; then
    cat dataset_images_interval_7.tar.gz.part_?? > dataset_images_interval_7.tar.gz
fi

echo
echo "=== extracting image archive ==="
if [[ ! -d dataset_images_interval_7 ]]; then
    tar -xzf dataset_images_interval_7.tar.gz
fi

echo
echo "=== cleanup: drop tar parts + merged archive to reclaim ~1.1 TB ==="
# Parts are regenerated by re-downloading if needed; merged tar can too.
rm -f dataset_images_interval_7.tar.gz.part_??
rm -f dataset_images_interval_7.tar.gz

echo
echo "=== final summary ==="
du -sh "$DEST"
find "$DEST" -maxdepth 1 -name "*.json" -exec ls -lh {} \;
echo "extracted image tree:"
find "$DEST/dataset_images_interval_7" -maxdepth 1 -type d | wc -l
date -u +%Y-%m-%dT%H:%M:%SZ
